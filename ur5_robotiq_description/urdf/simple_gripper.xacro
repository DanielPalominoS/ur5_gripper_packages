<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="simple_gripper" params="prefix parent_link origin_xyz:='0 0 0' origin_rpy:='0 0 0'">

    <!-- ========================= -->
    <!-- Base link (shorter)       -->
    <!-- ========================= -->
    <link name="${prefix}gripper_base_link">
      <visual>
        <geometry><box size="0.08 0.04 0.04"/></geometry>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <material name="ur_black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry><box size="0.08 0.04 0.04"/></geometry>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
    </link>

    <!-- Mount to tool0 -->
    <joint name="${prefix}gripper_mount_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}gripper_base_link"/>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
    </joint>

    <!-- ========================= -->
    <!-- Left finger joint         -->
    <!-- ========================= -->
    <joint name="${prefix}gripper_finger_joint" type="prismatic">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}left_finger_link"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.002" upper="0.042" effort="20" velocity="0.1"/>
    </joint>

    <link name="${prefix}left_finger_link">
      <visual>
        <geometry><box size="0.02 0.01 0.06"/></geometry>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry><box size="0.02 0.01 0.06"/></geometry>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                 iyy="0.0001" iyz="0.0"
                 izz="0.0001"/>
      </inertial>
      <material name="ur_black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </link>

    <!-- ========================= -->
    <!-- Right finger joint        -->
    <!-- ========================= -->
    <joint name="${prefix}right_finger_joint" type="prismatic">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}right_finger_link"/>
      <origin xyz="0 0 0.02" rpy="0 0 3.14159"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.002" upper="0.042" effort="20" velocity="0.1"/>
    </joint>

    <link name="${prefix}right_finger_link">
      <visual>
        <geometry><box size="0.02 0.01 0.06"/></geometry>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry><box size="0.02 0.01 0.06"/></geometry>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                 iyy="0.0001" iyz="0.0"
                 izz="0.0001"/>
      </inertial>
      <material name="ur_black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>

    </link>

    <!-- ========================= -->
    <!-- Transmissions             -->
    <!-- ========================= -->
    <transmission name="${prefix}gripper_left_transmission">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}gripper_finger_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}left_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <transmission name="${prefix}gripper_right_transmission">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}right_finger_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}right_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

  </xacro:macro>

</robot>